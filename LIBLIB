function Library:Progress(options)
    local text = options.Text or "Loading..."
    local duration = options.Duration or 5
    local color = options.Color or Config.AccentColor
    local callback = options.Callback or function() end

    local frame = CreateNotificationFrame(120)

    local bgGrad = AddGradient(frame, color, Config.PrimaryColor, 135)
    spawn(function()
        while frame and frame.Parent do
            for i = 0, 360, 4 do
                if not frame or not frame.Parent then break end
                bgGrad.Rotation = i
                wait(0.05)
            end
        end
    end)

    AddStroke(frame, color, 3)

    local mainGlow = AddGlow(frame, color)
    spawn(function()
        while mainGlow and mainGlow.Parent do
            CreateTween(mainGlow, {ImageTransparency = 0.3}, 0.8, Enum.EasingStyle.Sine):Play()
            wait(0.8)
            CreateTween(mainGlow, {ImageTransparency = 0.6}, 0.8, Enum.EasingStyle.Sine):Play()
            wait(0.8)
        end
    end)

    local textLabel = Instance.new("TextLabel")
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, -80, 0, 35)
    textLabel.Position = UDim2.new(0, 10, 0, 10)
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Text = text
    textLabel.TextColor3 = Config.TextColor
    textLabel.TextSize = 16
    textLabel.TextWrapped = true
    textLabel.ZIndex = 3
    textLabel.Parent = frame

    local percentLabel = Instance.new("TextLabel")
    percentLabel.BackgroundTransparency = 1
    percentLabel.Size = UDim2.new(0, 70, 0, 35)
    percentLabel.Position = UDim2.new(1, -75, 0, 10)
    percentLabel.Font = Enum.Font.GothamBold
    percentLabel.Text = "0%"
    percentLabel.TextColor3 = Config.SuccessColor
    percentLabel.TextSize = 18
    percentLabel.ZIndex = 3
    percentLabel.Parent = frame

    spawn(function()
        while percentLabel and percentLabel.Parent and percentLabel.Text ~= "100%" do
            CreateTween(percentLabel, {TextSize = 20}, 0.3):Play()
            wait(0.3)
            CreateTween(percentLabel, {TextSize = 18}, 0.3):Play()
            wait(0.3)
        end
    end)

    local progressBack = Instance.new("Frame")
    progressBack.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    progressBack.BorderSizePixel = 0
    progressBack.Size = UDim2.new(1, -20, 0, 28)
    progressBack.Position = UDim2.new(0, 10, 1, -40)
    progressBack.ZIndex = 2
    progressBack.Parent = frame

    AddCorner(progressBack, UDim.new(1, 0))
    AddStroke(progressBack, color, 2)

    local progressFill = Instance.new("Frame")
    progressFill.BackgroundColor3 = Config.SuccessColor
    progressFill.BorderSizePixel = 0
    progressFill.Size = UDim2.new(0, 0, 1, 0)
    progressFill.ZIndex = 3
    progressFill.Parent = progressBack

    AddCorner(progressFill, UDim.new(1, 0))
    local fillGrad = AddGradient(progressFill, Config.SuccessColor, Config.PrimaryColor, 0)

    spawn(function()
        while progressFill and progressFill.Parent do
            for i = 0, 360, 5 do
                if not progressFill or not progressFill.Parent then break end
                fillGrad.Rotation = i
                wait(0.05)
            end
        end
    end)

    local fillGlow = Instance.new("ImageLabel")
    fillGlow.BackgroundTransparency = 1
    fillGlow.Image = "rbxasset://textures/ui/Glow.png"
    fillGlow.ImageColor3 = Config.SuccessColor
    fillGlow.ImageTransparency = 0.4
    fillGlow.Size = UDim2.new(1, 30, 1, 30)
    fillGlow.Position = UDim2.new(0, -15, 0, -15)
    fillGlow.ZIndex = 2
    fillGlow.Parent = progressFill

    for i = 1, 5 do
        local spark = Instance.new("Frame")
        spark.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        spark.BorderSizePixel = 0
        spark.Size = UDim2.new(0, 3, 0, 3)
        spark.Position = UDim2.new(0, 0, 0.5, 0)
        spark.BackgroundTransparency = 0.3
        spark.ZIndex = 5
        spark.Parent = progressFill
        AddCorner(spark, UDim.new(1, 0))

        spawn(function()
            while spark and spark.Parent do
                local randY = math.random(-10, 10) / 10
                CreateTween(spark, {
                    Position = UDim2.new(1, 0, 0.5, randY),
                    BackgroundTransparency = 1
                }, 0.6, Enum.EasingStyle.Linear):Play()
                wait(0.6)
                spark.Position = UDim2.new(0, 0, 0.5, 0)
                spark.BackgroundTransparency = 0.3
                wait(0.1)
            end
        end)
    end

    spawn(function()
        local startTime = tick()
        while tick() - startTime < duration do
            local progress = (tick() - startTime) / duration
            progressFill.Size = UDim2.new(progress, 0, 1, 0)
            percentLabel.Text = math.floor(progress * 100) .. "%"
            wait(0.05)
        end

        progressFill.Size = UDim2.new(1, 0, 1, 0)
        percentLabel.Text = "100%"

        wait(0.5)
        callback()
        DismissNotification(frame)
    end)

    return frame
end

