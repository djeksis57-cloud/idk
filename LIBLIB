local Library = {}
Library.__index = Library

-- Services
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- Configuration (Hatsune Miku Color Scheme)
local Config = {
    -- Colors
    PrimaryColor = Color3.fromRGB(57, 197, 187),      -- Miku Cyan
    SecondaryColor = Color3.fromRGB(255, 105, 180),   -- Hot Pink
    AccentColor = Color3.fromRGB(138, 43, 226),       -- Blue Violet
    SuccessColor = Color3.fromRGB(0, 255, 127),       -- Spring Green
    ErrorColor = Color3.fromRGB(255, 69, 0),          -- Red Orange
    WarningColor = Color3.fromRGB(255, 215, 0),       -- Gold
    BackgroundColor = Color3.fromRGB(20, 20, 30),     -- Dark background
    TextColor = Color3.fromRGB(255, 255, 255),        -- White

    -- Animation Settings
    SlideSpeed = 0.4,
    FadeSpeed = 0.3,
    EasingStyle = Enum.EasingStyle.Back,
    EasingDirection = Enum.EasingDirection.Out,

    -- Notification Settings
    DefaultDuration = 4,
    NotificationHeight = 80,
    NotificationWidth = 350,
    Spacing = 10,
    CornerRadius = UDim.new(0, 12),
}

-- Active notifications queue
local activeNotifications = {}
local notificationContainer = nil

-- Utility Functions
local function CreateTween(instance, properties, duration, style, direction)
    duration = duration or Config.SlideSpeed
    style = style or Config.EasingStyle
    direction = direction or Config.EasingDirection

    local tweenInfo = TweenInfo.new(duration, style, direction)
    return TweenService:Create(instance, tweenInfo, properties)
end

local function AddCorner(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or Config.CornerRadius
    corner.Parent = instance
    return corner
end

local function AddStroke(instance, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Config.PrimaryColor
    stroke.Thickness = thickness or 2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Transparency = 0.3
    stroke.Parent = instance
    return stroke
end

local function AddGradient(instance, color1, color2, rotation)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, color1),
        ColorSequenceKeypoint.new(1, color2)
    }
    gradient.Rotation = rotation or 45
    gradient.Parent = instance
    return gradient
end

local function AddGlow(instance, color)
    local glow = Instance.new("ImageLabel")
    glow.Name = "Glow"
    glow.BackgroundTransparency = 1
    glow.Image = "rbxasset://textures/ui/Glow.png"
    glow.ImageColor3 = color or Config.PrimaryColor
    glow.ImageTransparency = 0.5
    glow.Size = UDim2.new(1, 40, 1, 40)
    glow.Position = UDim2.new(0, -20, 0, -20)
    glow.ZIndex = 0
    glow.Parent = instance
    return glow
end

-- Initialize notification container
local function InitializeContainer()
    if notificationContainer then return notificationContainer end

    local parent = CoreGui
    if not pcall(function() return CoreGui end) then
        parent = Players.LocalPlayer:WaitForChild("PlayerGui")
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "TextileNotifications"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn = false
    ScreenGui.DisplayOrder = 999999
    ScreenGui.Parent = parent

    local Container = Instance.new("Frame")
    Container.Name = "NotificationContainer"
    Container.BackgroundTransparency = 1
    Container.Position = UDim2.new(1, -Config.NotificationWidth - 20, 0, 20)
    Container.Size = UDim2.new(0, Config.NotificationWidth, 1, -40)
    Container.Parent = ScreenGui

    notificationContainer = Container
    return Container
end

-- Reposition all notifications
local function RepositionNotifications()
    local yOffset = 0
    for i, notif in ipairs(activeNotifications) do
        if notif and notif.Parent then
            CreateTween(notif, {
                Position = UDim2.new(0, 0, 0, yOffset)
            }, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out):Play()
            yOffset = yOffset + notif.Size.Y.Offset + Config.Spacing
        end
    end
end

-- Remove notification from queue
local function RemoveNotification(notification)
    for i, notif in ipairs(activeNotifications) do
        if notif == notification then
            table.remove(activeNotifications, i)
            break
        end
    end
    RepositionNotifications()
end

-- Create base notification frame
local function CreateNotificationFrame(height)
    local container = InitializeContainer()

    local Frame = Instance.new("Frame")
    Frame.BackgroundColor3 = Config.BackgroundColor
    Frame.BorderSizePixel = 0
    Frame.Size = UDim2.new(1, 0, 0, height or Config.NotificationHeight)
    Frame.Position = UDim2.new(1, 50, 0, 0) -- Start off-screen
    Frame.Parent = container

    AddCorner(Frame)

    table.insert(activeNotifications, Frame)

    -- Slide in animation
    task.wait(0.05)
    CreateTween(Frame, {
        Position = UDim2.new(0, 0, 0, 0)
    }, Config.SlideSpeed):Play()

    RepositionNotifications()

    return Frame
end

-- Dismiss notification with animation
local function DismissNotification(frame, duration)
    duration = duration or 0.3

    CreateTween(frame, {
        Position = UDim2.new(1, 50, frame.Position.Y.Scale, frame.Position.Y.Offset)
    }, duration):Play()

    for _, child in ipairs(frame:GetDescendants()) do
        if child:IsA("GuiObject") then
            CreateTween(child, {BackgroundTransparency = 1}, duration):Play()
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                CreateTween(child, {TextTransparency = 1}, duration):Play()
            end
            if child:IsA("ImageLabel") then
                CreateTween(child, {ImageTransparency = 1}, duration):Play()
            end
        end
    end

    task.delay(duration, function()
        RemoveNotification(frame)
        frame:Destroy()
    end)
end

-- Library Functions

-- 1. Simple Text Notification
function Library:Notify(options)
    if type(options) == "string" then
        options = {Text = options}
    end

    local text = options.Text or "Notification"
    local duration = options.Duration or Config.DefaultDuration
    local color = options.Color or Config.PrimaryColor
    local icon = options.Icon or "✨"

    local frame = CreateNotificationFrame(Config.NotificationHeight)

    AddGradient(frame, color, Color3.fromRGB(
        math.clamp(color.R * 255 + 30, 0, 255),
        math.clamp(color.G * 255 + 30, 0, 255),
        math.clamp(color.B * 255 + 30, 0, 255)
    ):ToColor3(), 45)

    AddStroke(frame, color, 2)
    AddGlow(frame, color)

    -- Icon
    local Icon = Instance.new("TextLabel")
    Icon.BackgroundTransparency = 1
    Icon.Size = UDim2.new(0, 50, 1, 0)
    Icon.Position = UDim2.new(0, 0, 0, 0)
    Icon.Font = Enum.Font.GothamBold
    Icon.Text = icon
    Icon.TextColor3 = Config.TextColor
    Icon.TextSize = 32
    Icon.Parent = frame

    -- Text
    local TextLabel = Instance.new("TextLabel")
    TextLabel.BackgroundTransparency = 1
    TextLabel.Size = UDim2.new(1, -60, 1, 0)
    TextLabel.Position = UDim2.new(0, 55, 0, 0)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.Text = text
    TextLabel.TextColor3 = Config.TextColor
    TextLabel.TextSize = 16
    TextLabel.TextWrapped = true
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.Parent = frame

    -- Shimmer effect
    local shimmer = Instance.new("Frame")
    shimmer.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    shimmer.BackgroundTransparency = 0.7
    shimmer.BorderSizePixel = 0
    shimmer.Size = UDim2.new(0, 50, 2, 0)
    shimmer.Position = UDim2.new(-0.2, 0, -0.5, 0)
    shimmer.Rotation = 45
    shimmer.ZIndex = 10
    shimmer.Parent = frame

    -- Animate shimmer
    spawn(function()
        wait(0.3)
        CreateTween(shimmer, {
            Position = UDim2.new(1.2, 0, -0.5, 0)
        }, 0.8, Enum.EasingStyle.Linear):Play()
    end)

    -- Auto dismiss
    task.delay(duration, function()
        if frame and frame.Parent then
            DismissNotification(frame)
        end
    end)

    return frame
end

-- 2. Decision Notification (Left/Right buttons)
function Library:Decision(options)
    local text = options.Text or "Make a choice"
    local leftText = options.LeftButton or "Cancel"
    local rightText = options.RightButton or "Confirm"
    local leftCallback = options.LeftCallback or function() end
    local rightCallback = options.RightCallback or function() end
    local color = options.Color or Config.SecondaryColor

    local frame = CreateNotificationFrame(120)

    AddGradient(frame, color, Config.AccentColor, 90)
    AddStroke(frame, color, 2)
    AddGlow(frame, color)

    -- Text
    local TextLabel = Instance.new("TextLabel")
    TextLabel.BackgroundTransparency = 1
    TextLabel.Size = UDim2.new(1, -20, 0, 50)
    TextLabel.Position = UDim2.new(0, 10, 0, 10)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.Text = text
    TextLabel.TextColor3 = Config.TextColor
    TextLabel.TextSize = 15
    TextLabel.TextWrapped = true
    TextLabel.Parent = frame

    -- Left Button
    local LeftButton = Instance.new("TextButton")
    LeftButton.BackgroundColor3 = Color3.fromRGB(255, 69, 0)
    LeftButton.BorderSizePixel = 0
    LeftButton.Size = UDim2.new(0.48, 0, 0, 40)
    LeftButton.Position = UDim2.new(0.02, 0, 1, -50)
    LeftButton.Font = Enum.Font.GothamBold
    LeftButton.Text = leftText
    LeftButton.TextColor3 = Config.TextColor
    LeftButton.TextSize = 14
    LeftButton.Parent = frame

    AddCorner(LeftButton, UDim.new(0, 8))

    LeftButton.MouseButton1Click:Connect(function()
        leftCallback()
        DismissNotification(frame, 0.2)
    end)

    LeftButton.MouseEnter:Connect(function()
        CreateTween(LeftButton, {Size = UDim2.new(0.48, 0, 0, 43)}, 0.1):Play()
    end)

    LeftButton.MouseLeave:Connect(function()
        CreateTween(LeftButton, {Size = UDim2.new(0.48, 0, 0, 40)}, 0.1):Play()
    end)

    -- Right Button
    local RightButton = Instance.new("TextButton")
    RightButton.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
    RightButton.BorderSizePixel = 0
    RightButton.Size = UDim2.new(0.48, 0, 0, 40)
    RightButton.Position = UDim2.new(0.5, 0, 1, -50)
    RightButton.Font = Enum.Font.GothamBold
    RightButton.Text = rightText
    RightButton.TextColor3 = Config.BackgroundColor
    RightButton.TextSize = 14
    RightButton.Parent = frame

    AddCorner(RightButton, UDim.new(0, 8))

    RightButton.MouseButton1Click:Connect(function()
        rightCallback()
        DismissNotification(frame, 0.2)
    end)

    RightButton.MouseEnter:Connect(function()
        CreateTween(RightButton, {Size = UDim2.new(0.48, 0, 0, 43)}, 0.1):Play()
    end)

    RightButton.MouseLeave:Connect(function()
        CreateTween(RightButton, {Size = UDim2.new(0.48, 0, 0, 40)}, 0.1):Play()
    end)

    return frame
end

-- 3. Progress Bar Notification
function Library:Progress(options)
    local text = options.Text or "Loading..."
    local duration = options.Duration or 5
    local color = options.Color or Config.AccentColor
    local callback = options.Callback or function() end

    local frame = CreateNotificationFrame(100)

    AddGradient(frame, color, Config.PrimaryColor, 135)
    AddStroke(frame, color, 2)
    AddGlow(frame, color)

    -- Text
    local TextLabel = Instance.new("TextLabel")
    TextLabel.BackgroundTransparency = 1
    TextLabel.Size = UDim2.new(1, -20, 0, 30)
    TextLabel.Position = UDim2.new(0, 10, 0, 10)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.Text = text
    TextLabel.TextColor3 = Config.TextColor
    TextLabel.TextSize = 15
    TextLabel.TextWrapped = true
    TextLabel.Parent = frame

    -- Percentage
    local PercentLabel = Instance.new("TextLabel")
    PercentLabel.BackgroundTransparency = 1
    PercentLabel.Size = UDim2.new(0, 60, 0, 30)
    PercentLabel.Position = UDim2.new(1, -70, 0, 10)
    PercentLabel.Font = Enum.Font.GothamBold
    PercentLabel.Text = "0%"
    PercentLabel.TextColor3 = Config.SuccessColor
    PercentLabel.TextSize = 16
    PercentLabel.Parent = frame

    -- Progress Bar Background
    local ProgressBack = Instance.new("Frame")
    ProgressBack.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    ProgressBack.BorderSizePixel = 0
    ProgressBack.Size = UDim2.new(1, -20, 0, 20)
    ProgressBack.Position = UDim2.new(0, 10, 1, -35)
    ProgressBack.Parent = frame

    AddCorner(ProgressBack, UDim.new(1, 0))

    -- Progress Bar Fill
    local ProgressFill = Instance.new("Frame")
    ProgressFill.BackgroundColor3 = Config.SuccessColor
    ProgressFill.BorderSizePixel = 0
    ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    ProgressFill.Parent = ProgressBack

    AddCorner(ProgressFill, UDim.new(1, 0))
    AddGradient(ProgressFill, Config.SuccessColor, Config.PrimaryColor, 0)

    -- Animate progress
    spawn(function()
        local startTime = tick()
        while tick() - startTime < duration do
            local progress = (tick() - startTime) / duration
            ProgressFill.Size = UDim2.new(progress, 0, 1, 0)
            PercentLabel.Text = math.floor(progress * 100) .. "%"
            wait(0.05)
        end

        ProgressFill.Size = UDim2.new(1, 0, 1, 0)
        PercentLabel.Text = "100%"

        wait(0.5)
        callback()
        DismissNotification(frame)
    end)

    return frame
end

-- 4. Input Notification (Text input)
function Library:Input(options)
    local text = options.Text or "Enter text:"
    local placeholder = options.Placeholder or "Type here..."
    local callback = options.Callback or function() end
    local color = options.Color or Config.PrimaryColor

    local frame = CreateNotificationFrame(130)

    AddGradient(frame, color, Config.SecondaryColor, 60)
    AddStroke(frame, color, 2)
    AddGlow(frame, color)

    -- Text
    local TextLabel = Instance.new("TextLabel")
    TextLabel.BackgroundTransparency = 1
    TextLabel.Size = UDim2.new(1, -20, 0, 30)
    TextLabel.Position = UDim2.new(0, 10, 0, 10)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.Text = text
    TextLabel.TextColor3 = Config.TextColor
    TextLabel.TextSize = 15
    TextLabel.TextWrapped = true
    TextLabel.Parent = frame

    -- Input Box
    local InputBox = Instance.new("TextBox")
    InputBox.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    InputBox.BorderSizePixel = 0
    InputBox.Size = UDim2.new(1, -20, 0, 35)
    InputBox.Position = UDim2.new(0, 10, 0, 45)
    InputBox.Font = Enum.Font.Gotham
    InputBox.PlaceholderText = placeholder
    InputBox.Text = ""
    InputBox.TextColor3 = Config.TextColor
    InputBox.TextSize = 14
    InputBox.ClearTextOnFocus = false
    InputBox.Parent = frame

    AddCorner(InputBox, UDim.new(0, 8))
    AddStroke(InputBox, color, 1)

    local InputPadding = Instance.new("UIPadding")
    InputPadding.PaddingLeft = UDim.new(0, 10)
    InputPadding.PaddingRight = UDim.new(0, 10)
    InputPadding.Parent = InputBox

    -- Submit Button
    local SubmitButton = Instance.new("TextButton")
    SubmitButton.BackgroundColor3 = color
    SubmitButton.BorderSizePixel = 0
    SubmitButton.Size = UDim2.new(1, -20, 0, 35)
    SubmitButton.Position = UDim2.new(0, 10, 1, -45)
    SubmitButton.Font = Enum.Font.GothamBold
    SubmitButton.Text = "Submit"
    SubmitButton.TextColor3 = Config.TextColor
    SubmitButton.TextSize = 14
    SubmitButton.Parent = frame

    AddCorner(SubmitButton, UDim.new(0, 8))

    local function submit()
        local inputText = InputBox.Text
        callback(inputText)
        DismissNotification(frame, 0.2)
    end

    SubmitButton.MouseButton1Click:Connect(submit)

    InputBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            submit()
        end
    end)

    SubmitButton.MouseEnter:Connect(function()
        CreateTween(SubmitButton, {BackgroundColor3 = Color3.fromRGB(
            math.clamp(color.R * 255 + 30, 0, 255),
            math.clamp(color.G * 255 + 30, 0, 255),
            math.clamp(color.B * 255 + 30, 0, 255)
        ):ToColor3()}, 0.2):Play()
    end)

    SubmitButton.MouseLeave:Connect(function()
        CreateTween(SubmitButton, {BackgroundColor3 = color}, 0.2):Play()
    end)

    return frame
end

-- 5. Image Notification (with icon/image)
function Library:Image(options)
    local text = options.Text or "Notification"
    local imageId = options.ImageId or "rbxassetid://0"
    local duration = options.Duration or Config.DefaultDuration
    local color = options.Color or Config.SecondaryColor

    local frame = CreateNotificationFrame(100)

    AddGradient(frame, color, Config.AccentColor, 120)
    AddStroke(frame, color, 2)
    AddGlow(frame, color)

    -- Image
    local Image = Instance.new("ImageLabel")
    Image.BackgroundTransparency = 1
    Image.Size = UDim2.new(0, 70, 0, 70)
    Image.Position = UDim2.new(0, 10, 0.5, -35)
    Image.Image = imageId
    Image.Parent = frame

    AddCorner(Image, UDim.new(0, 10))

    -- Text
    local TextLabel = Instance.new("TextLabel")
    TextLabel.BackgroundTransparency = 1
    TextLabel.Size = UDim2.new(1, -100, 1, -20)
    TextLabel.Position = UDim2.new(0, 90, 0, 10)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.Text = text
    TextLabel.TextColor3 = Config.TextColor
    TextLabel.TextSize = 15
    TextLabel.TextWrapped = true
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.TextYAlignment = Enum.TextYAlignment.Top
    TextLabel.Parent = frame

    -- Auto dismiss
    task.delay(duration, function()
        if frame and frame.Parent then
            DismissNotification(frame)
        end
    end)

    return frame
end

-- 6. Success Notification
function Library:Success(text, duration)
    return self:Notify({
        Text = text or "Success!",
        Duration = duration or Config.DefaultDuration,
        Color = Config.SuccessColor,
        Icon = "✓"
    })
end

-- 7. Error Notification
function Library:Error(text, duration)
    return self:Notify({
        Text = text or "Error!",
        Duration = duration or Config.DefaultDuration,
        Color = Config.ErrorColor,
        Icon = "✗"
    })
end

-- 8. Warning Notification
function Library:Warning(text, duration)
    return self:Notify({
        Text = text or "Warning!",
        Duration = duration or Config.DefaultDuration,
        Color = Config.WarningColor,
        Icon = "⚠"
    })
end

-- Clear all notifications
function Library:ClearAll()
    for _, notif in ipairs(activeNotifications) do
        if notif and notif.Parent then
            DismissNotification(notif, 0.1)
        end
    end
    activeNotifications = {}
end

return Library
