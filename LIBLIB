        choiceLabel.Font = Enum.Font.Gotham
        choiceLabel.Text = choice
        choiceLabel.TextColor3 = Config.TextColor
        choiceLabel.TextSize = 14
        choiceLabel.TextXAlignment = Enum.TextXAlignment.Left
        choiceLabel.ZIndex = 3
        choiceLabel.Parent = choiceFrame

        checkbox.MouseButton1Click:Connect(function()
            if selected[choice] then
                selected[choice] = nil
                CreateTween(checkmark, {BackgroundTransparency = 1}, 0.2):Play()
            else
                selected[choice] = true
                CreateTween(checkmark, {BackgroundTransparency = 0}, 0.2):Play()
            end
        end)
    end

    local submitButton = Instance.new("TextButton")
    submitButton.BackgroundColor3 = color
    submitButton.BorderSizePixel = 0
    submitButton.Size = UDim2.new(1, -20, 0, 40)
    submitButton.Position = UDim2.new(0, 10, 1, -50)
    submitButton.Font = Enum.Font.GothamBold
    submitButton.Text = "Submit"
    submitButton.TextColor3 = Config.TextColor
    submitButton.TextSize = 16
    submitButton.ZIndex = 3
    submitButton.Parent = frame

    AddCorner(submitButton, UDim.new(0, 10))
    AddGradient(submitButton, color, Config.AccentColor, 45)
    AddStroke(submitButton, Config.TextColor, 2)

    submitButton.MouseButton1Click:Connect(function()
        local selectedList = {}
        for choice, _ in pairs(selected) do
            table.insert(selectedList, choice)
        end
        callback(selectedList)
        DismissNotification(frame, 0.2)
    end)

    submitButton.MouseEnter:Connect(function()
        CreateTween(submitButton, {Size = UDim2.new(1, -20, 0, 43)}, 0.15):Play()
    end)

    submitButton.MouseLeave:Connect(function()
        CreateTween(submitButton, {Size = UDim2.new(1, -20, 0, 40)}, 0.15):Play()
    end)

    return frame
end

function Library:Toast(text, duration)
    local frame = CreateNotificationFrame(60)

    local color = Config.PrimaryColor
    local bgGrad = AddGradient(frame, color, Config.SecondaryColor, 90)
    AddStroke(frame, color, 2)

    local textLabel = Instance.new("TextLabel")
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, -20, 1, 0)
    textLabel.Position = UDim2.new(0, 10, 0, 0)
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Text = text or "Toast"
    textLabel.TextColor3 = Config.TextColor
    textLabel.TextSize = 15
    textLabel.TextWrapped = true
    textLabel.ZIndex = 3
    textLabel.Parent = frame

    task.delay(duration or 2, function()
        if frame and frame.Parent then
            DismissNotification(frame)
        end
    end)

    return frame
end

return Library
